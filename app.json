{
  "expo": {
    "name": "Bihari Library",
    "description": "A unit of Bihari Traders",
    "slug": "bihari-library",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/bihari.png",
    "userInterfaceStyle": "light",
    "androidStatusBar": {
      "backgroundColor": "#8B5CF6",
      "barStyle": "light-content",
      "translucent": false
    },
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/bihari.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.roottechnology.biharilibrary",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tejasvibihari.biharilibrary",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/bihari.png",
        "backgroundColor": "#ffffff"
      },
      "intentFilters": [
        {
          "action": "android.intent.action.CALL",
          "category": [
            "android.intent.category.DEFAULT"
          ],
          "data": [
            {
              "scheme": "tel"
            }
          ]
        },
        {
          "action": "android.intent.action.SENDTO",
          "category": [
            "android.intent.category.DEFAULT"
          ],
          "data": [
            {
              "scheme": "sms"
            }
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/bihari.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "1fea9d36-b97b-4d27-ad87-9dcbe2b6d97a"
      }
    },
    "owner": "tejasvibihari"
  }
}